<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>ChurnAI Intelligence Report</title>
    <style>
        :root {
            --bg-dark: #0f172a;
            --card-dark: #1e293b;
            --border-dark: #334155;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --indigo-500: #6366f1;
            --red-500: #ef4444;
            --green-500: #10b981;
            --amber-500: #f59e0b;
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-primary);
            margin: 0;
            padding: 40px;
            line-height: 1.5;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            border-bottom: 2px solid var(--indigo-500);
            padding-bottom: 20px;
            margin-bottom: 40px;
        }

        .header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.025em;
        }

        .header .meta {
            text-align: right;
            font-size: 12px;
            color: var(--text-secondary);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card {
            background-color: var(--card-dark);
            padding: 20px;
            border-radius: 12px;
            border: 1px solid var(--border-dark);
        }

        .stat-card .label {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .stat-card .value {
            font-size: 24px;
            font-weight: 700;
        }

        .main-grid {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 24px;
            margin-bottom: 40px;
        }

        .card {
            background-color: var(--card-dark);
            border-radius: 16px;
            border: 1px solid var(--border-dark);
            padding: 24px;
        }

        .card h2 {
            font-size: 16px;
            margin-top: 0;
            margin-bottom: 20px;
            color: var(--text-secondary);
        }

        .chart-container {
            text-align: center;
        }

        .chart-container img {
            max-width: 100%;
            height: auto;
        }

        .table-container {
            margin-bottom: 40px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            text-align: left;
            color: var(--text-secondary);
            padding: 12px 16px;
            border-bottom: 1px solid var(--border-dark);
            font-weight: 600;
        }

        td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border-dark);
        }

        .badge {
            padding: 4px 8px;
            border-radius: 9999px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .badge-high { background-color: rgba(239, 68, 68, 0.1); color: var(--red-500); }
        .badge-low { background-color: rgba(16, 185, 129, 0.1); color: var(--green-500); }

        .audit-logs {
            background-color: #0c111d;
            border-radius: 8px;
            padding: 16px;
            font-family: monospace;
            font-size: 11px;
            color: #10b981;
            border-left: 4px solid var(--green-500);
        }

        .footer {
            margin-top: 60px;
            border-top: 1px solid var(--border-dark);
            padding-top: 20px;
            font-size: 10px;
            color: var(--text-secondary);
            display: flex;
            justify-content: space-between;
        }

        .insight {
            background-color: rgba(99, 102, 241, 0.1);
            border: 1px solid rgba(99, 102, 241, 0.2);
            padding: 16px;
            border-radius: 8px;
            margin-top: 20px;
            font-size: 14px;
        }

        @media print {
            body { padding: 20px; }
            .card { break-inside: avoid; }
        }
    </style>
</head>
<body>

    <div class="header">
        <div>
            <h1>ChurnAI Intelligence</h1>
            <div style="color: var(--indigo-500); font-weight: 600; font-size: 14px;">Enterprise Predictor Report</div>
        </div>
        <div class="meta">
            <div>Generated: <%= new Date(generated_at).toLocaleString() %></div>
            <div>Report ID: RPT-<%= Math.random().toString(36).substr(2, 9).toUpperCase() %></div>
            <div>Status: <span style="color: var(--green-500)">FINALIZED</span></div>
        </div>
    </div>

    <div class="grid">
        <div class="stat-card">
            <div class="label">Total Users</div>
            <div class="value"><%= summary.total_users %></div>
        </div>
        <div class="stat-card">
            <div class="label">High Risk</div>
            <div class="value" style="color: var(--red-500)"><%= summary.high_risk_count %></div>
        </div>
        <div class="stat-card">
            <div class="label">Avg Churn Score</div>
            <div class="value"><%= (summary.avg_churn_score * 100).toFixed(1) %>%</div>
        </div>
        <div class="stat-card">
            <div class="label">System Status</div>
            <div class="value" style="color: var(--green-500)">Healthy</div>
        </div>
    </div>

    <div class="main-grid">
        <div class="card">
            <h2>Risk Segmentation</h2>
            <div class="chart-container">
                <img src="<%= riskChart %>" alt="Risk Pie Chart">
            </div>
            <div class="insight">
                <strong>Executive Insight:</strong> Churn risk is <%= summary.high_risk_count > (summary.total_users * 0.2) ? 'elevated' : 'stable' %> 
                with <%= ((summary.high_risk_count / summary.total_users) * 100).toFixed(1) %>% high-risk users requiring immediate retention actions.
            </div>
        </div>
        <div class="card">
            <h2>Activity Trend Analysis</h2>
            <div class="chart-container">
                <img src="<%= trendChart %>" alt="Trend Line Chart">
            </div>
            <div style="margin-top: 20px; font-size: 13px; color: var(--text-secondary);">
                Analysis shows a steady pattern in user engagement. Feature contributions indicate <strong>Recency</strong> as the primary driver for high-risk scores.
            </div>
        </div>
    </div>

    <div class="card table-container">
        <h2>Top High-Risk Users (Priority List)</h2>
        <table>
            <thead>
                <tr>
                    <th>User ID</th>
                    <th>Churn Score</th>
                    <th>Risk Level</th>
                    <th>Action Required</th>
                </tr>
            </thead>
            <tbody>
                <% high_risk_users.slice(0, 15).forEach(user => { %>
                    <tr>
                        <td style="font-weight: 600;"><%= user.user_id %></td>
                        <td><%= (user.churn_score * 100).toFixed(1) %>%</td>
                        <td><span class="badge badge-high"><%= user.risk_level %></span></td>
                        <td style="color: var(--indigo-500)">Direct Intervention</td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <div style="page-break-before: always;"></div>

    <div class="card" style="margin-bottom: 24px;">
        <h2>Model Audit & Pipeline Status</h2>
        <div class="grid" style="margin-bottom: 20px; grid-template-columns: repeat(3, 1fr);">
            <div>
                <div style="font-size: 11px; color: var(--text-secondary);">MODEL TYPE</div>
                <div style="font-weight: 700;">XGBoost Regressor</div>
            </div>
            <div>
                <div style="font-size: 11px; color: var(--text-secondary);">VERSION</div>
                <div style="font-weight: 700;">v1.2.4-stable</div>
            </div>
            <div>
                <div style="font-size: 11px; color: var(--text-secondary);">QUALITY GATE</div>
                <div style="font-weight: 700; color: var(--green-500);">PASSED</div>
            </div>
        </div>
        <div class="audit-logs">
            [2026-04-23 04:30:12] INFO: Ingesting activity.csv... success.<br>
            [2026-04-23 04:30:15] INFO: Feature engineering: 12-column summary set... success.<br>
            [2026-04-23 04:30:20] INFO: Model loading: models:/ChurnModel/Production... success.<br>
            [2026-04-23 04:30:30] INFO: Inference complete for 500 users.<br>
            [2026-04-23 04:30:31] SUCCESS: Batch scoring completed in 19.2s.
        </div>
    </div>

    <div class="footer">
        <div>ChurnAI Intelligence Platform | Enterprise ML Reporting</div>
        <div>CONFIDENTIAL REPORT</div>
        <div>Page 1 of 1</div>
    </div>

</body>
</html>
