# ── ML Artifacts & Data ───────────────────────────────────────────────────────
# Ignore the MLflow database and artifacts
ml-service/mlflow/
ml-service/mlruns/
ml-service/mlflow.db

# Ignore generated PDF reports and batch results
ml-service/reports/output/
ml-service/data/batch_results/

# Ignore large CSV datasets (but keep sample scripts and specific test files)
ml-service/data/*.csv
!ml-service/data/activity.csv
!ml-service/data/users.csv

